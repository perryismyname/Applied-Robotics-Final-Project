# MAIN STATE MACHINE

class CaptureTheFlag(StateMachineProgram):
    def __init__(self):
        pf = SLAMParticleFilter(
            robot,
            landmark_test=SLAMSensorModel.is_solo_aruco_landmark)
        super().__init__(
            wall_marker_dict=dict(),
            particle_filter=pf,
            launch_particle_viewer=True,
            launch_path_viewer=True,
            speech=False)

    $setup {
        # LOCALIZATION
        # Enable tag AND model (AI-object) detection, then spin 360 degrees
        # pausing for SLAM to register markers.  Model detection is what makes
        # barrels show up in the world map; without it FindBestBarrel sees none.
        init: TagDetection(enabled=True)
        init =C=> ModelDetection(enabled=True) =C=> Localize() =C=> prompt_start

        # GAME START
        # Wait for spoken word "start" to begin game
        prompt_start: Say("Localized, say start to begin")
        prompt_start =Hear('start')=> say_starting

        say_starting: Say("Starting game")
        say_starting =C=> start_timer

        start_timer: StartTimer()
        start_timer =C=> game_loop

        # BARREL COLLECTION LOOP
        # Find nearest barrel, pick it up, verify, repeat
        # NOTE: Pickup currently uses PickUp internal path planning which
        # sometimes fails at close range due to built-in detector limitations

        game_loop: CheckTimeUp()
        game_loop =F=> choose_barrel
        game_loop =S=> game_end

        game_end : Say("stop everything!")


        # Taunt only after a successful drop-off (not before every pickup, where
        # the movement-based events would shove the robot off its approach).
        random_event : RandomEvent()
        random_event =C=> game_loop


        choose_barrel : FindBestBarrel()
        choose_barrel =F=> steal
        choose_barrel =D=> StoreBarrel() =D=> turn_to

        # STEAL FALLBACK
        # FindBestBarrel ignores barrels sitting within 100mm of any tag, so a
        # barrel parked at an enemy goal never gets chosen above -- that is what
        # steal goes after.  StealBarrel drives to a side-standoff near such a
        # barrel and hands it up as a DataEvent, so we pursue it on the very
        # same path as one we found ourselves.  It fails when there is nothing
        # to steal (and immediately when ALLOW_STEAL is False), in which case we
        # re-localize and loop -- exactly what choose_barrel's failure branch
        # used to do.
        steal: StealBarrel(MY_BARREL_TYPES, ENEMY_TAGS, MY_TAGS, ALLOW_STEAL)
        steal =D=> StoreBarrel() =D=> turn_to
        steal =F=> Localize() =C=> game_loop

        pickup: StoredPickUp()
        pickup =C=> barrel_dropoff
        pickup =F=> Say("failed pickup") =C=> game_loop

        turn_to: TurnToward()
        turn_to =C=> StateNode() =T(2)=> GetCurrentBarrel() =D=> go_to

        go_to: GoTo()
        go_to =C=> StateNode() =T(1)=> grab_check

        # Verify we actually grabbed; on a miss, back up and re-approach a few
        # times before moving on (one drive often doesn't seat the barrel).
        grab_check: GrabCheck()
        grab_check =S=> barrel_dropoff
        grab_check =F=> grab_retry

        grab_retry: GrabRetry()
        grab_retry =S=> Forward(-PICKUP_BACKUP_MM) =C=> StateNode() =T(1)=> GetCurrentBarrel() =D=> turn_to
        grab_retry =F=> game_loop

        check_hold: CheckHolding()
        check_hold =S=> GetCurrentBarrel() =D=> barrel_dropoff
        check_hold =F=> game_loop

        barrel_dropoff : BarrelDropoff()
        barrel_dropoff =C=> random_event
        barrel_dropoff =F=> game_loop
    }
