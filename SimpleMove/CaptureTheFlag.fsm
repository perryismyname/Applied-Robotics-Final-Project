# MAIN STATE MACHINE

class CaptureTheFlag(StateMachineProgram):
    def __init__(self):
        pf = SLAMParticleFilter(
            robot,
            landmark_test=SLAMSensorModel.is_solo_aruco_landmark)
        super().__init__(
            wall_marker_dict=dict(),
            particle_filter=pf,
            launch_particle_viewer=True,
            launch_path_viewer=True,
            speech=False)

    $setup {
        # LOCALIZATION
        # Enable tag detection, spin 360 degrees pausing for SLAM to register markers
        init: TagDetection(enabled=True)

        init =C=> Localize() =C=> prompt_start

        # GAME START
        # Wait for spoken word "start" to begin game
        prompt_start: Say("Localized, say start to begin")
        prompt_start =Hear('start')=> say_starting

        say_starting: Say("Starting game")
        say_starting =C=> start_timer

        start_timer: StartTimer()
        start_timer =C=> game_loop

        # BARREL COLLECTION LOOP
        # Find nearest barrel, pick it up, verify, repeat
        # NOTE: Pickup currently uses PickUp internal path planning which
        # sometimes fails at close range due to built-in detector limitations

        game_loop: CheckTimeUp()
        game_loop =F=> random_event
        game_loop =S=> game_end

        game_end : Say("stop everything!")


        random_event : RandomEvent()
        random_event =C=> StateNode() =T(2)=> choose_barrel


        choose_barrel : FindBestBarrel()
        choose_barrel =F=> Localize() =C=> game_loop
        choose_barrel =D=> StoreBarrel() =D=> turn_to

        pickup: StoredPickUp()
        pickup =C=> barrel_dropoff
        pickup =F=> Say("failed pickup") =C=> game_loop

        turn_to: TurnToward()
        turn_to =C=> StateNode() =T(2)=> GetCurrentBarrel() =D=> go_to

        go_to: GoTo() 
        go_to =C=> StateNode() =T(2)=> GetCurrentBarrel() =D=> barrel_dropoff

        check_hold: CheckHolding()
        check_hold =S=> GetCurrentBarrel() =D=> barrel_dropoff
        check_hold =F=> game_loop

        barrel_dropoff : BarrelDropoff()
        barrel_dropoff =C=> StateNode() =T(2)=> game_loop
        barrel_dropoff =F=> game_loop
    }
